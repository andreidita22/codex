{
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["continuation_bridge_v2"]
    },
    "task": {
      "type": "object",
      "properties": {
        "objective": { "type": "string" },
        "current_phase": { "type": "string" },
        "success_condition": { "type": "string" }
      },
      "required": ["objective", "current_phase", "success_condition"],
      "additionalProperties": false
    },
    "repo_identity": {
      "type": "object",
      "properties": {
        "repo_root": { "type": "string" },
        "branch": { "type": "string" },
        "head_commit": { "type": "string" },
        "worktree_dirty": { "type": "boolean" },
        "dirty_files": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["repo_root", "branch", "head_commit", "worktree_dirty", "dirty_files"],
      "additionalProperties": false
    },
    "state": {
      "type": "object",
      "properties": {
        "completed": { "type": "array", "items": { "type": "string" } },
        "in_progress": { "type": "array", "items": { "type": "string" } },
        "not_started": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["completed", "in_progress", "not_started"],
      "additionalProperties": false
    },
    "blocking_state": {
      "type": "object",
      "properties": {
        "blocking": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": { "type": "string" },
              "reason": { "type": "string" },
              "owner": { "type": "string" },
              "unblocks": { "type": "string" }
            },
            "required": ["kind", "reason", "owner", "unblocks"],
            "additionalProperties": false
          }
        },
        "non_blocking": { "type": "array", "items": { "type": "string" } },
        "optional_followups": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["blocking", "non_blocking", "optional_followups"],
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "files_touched": { "type": "array", "items": { "type": "string" } },
        "authoritative_files": { "type": "array", "items": { "type": "string" } },
        "partial_implementations": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["files_touched", "authoritative_files", "partial_implementations"],
      "additionalProperties": false
    },
    "active_subagents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent_id": { "type": "string" },
          "thread_id": { "type": "string" },
          "role": { "type": "string" },
          "task": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed"]
          },
          "blocking": { "type": "boolean" },
          "last_result_summary": { "type": "string" }
        },
        "required": [
          "agent_id",
          "thread_id",
          "role",
          "task",
          "status",
          "blocking",
          "last_result_summary"
        ],
        "additionalProperties": false
      }
    },
    "key_claims_with_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "ready_for_output": { "type": "boolean" },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "line": { "type": "integer", "minimum": 1 },
                "kind": { "type": "string" },
                "why_it_supports_claim": { "type": "string" }
              },
              "required": ["path", "line", "kind", "why_it_supports_claim"],
              "additionalProperties": false
            }
          }
        },
        "required": ["claim", "confidence", "ready_for_output", "evidence"],
        "additionalProperties": false
      }
    },
    "invariants": {
      "type": "object",
      "properties": {
        "must_preserve": { "type": "array", "items": { "type": "string" } },
        "must_not_do": { "type": "array", "items": { "type": "string" } },
        "assumptions_in_force": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["must_preserve", "must_not_do", "assumptions_in_force"],
      "additionalProperties": false
    },
    "epistemics": {
      "type": "object",
      "properties": {
        "known_uncertainties": { "type": "array", "items": { "type": "string" } },
        "questions_already_resolved": { "type": "array", "items": { "type": "string" } },
        "questions_still_open": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["known_uncertainties", "questions_already_resolved", "questions_still_open"],
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "properties": {
        "why_current_code_looks_like_this": { "type": "array", "items": { "type": "string" } },
        "rejected_paths": { "type": "array", "items": { "type": "string" } },
        "pending_decisions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["why_current_code_looks_like_this", "rejected_paths", "pending_decisions"],
      "additionalProperties": false
    },
    "working_thesis": {
      "type": "object",
      "properties": {
        "current_best_answer": { "type": "string" },
        "main_caveats": { "type": "array", "items": { "type": "string" } },
        "likely_conclusion": { "type": "string" }
      },
      "required": ["current_best_answer", "main_caveats", "likely_conclusion"],
      "additionalProperties": false
    },
    "recommended_output_shape": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next": {
      "type": "object",
      "properties": {
        "immediate_next_action": { "type": "string" },
        "fallback_if_blocked": { "type": "string" },
        "validation_step": { "type": "string" }
      },
      "required": ["immediate_next_action", "fallback_if_blocked", "validation_step"],
      "additionalProperties": false
    }
  },
  "required": [
    "schema",
    "task",
    "repo_identity",
    "state",
    "blocking_state",
    "artifacts",
    "active_subagents",
    "key_claims_with_evidence",
    "invariants",
    "epistemics",
    "provenance",
    "working_thesis",
    "recommended_output_shape",
    "next"
  ],
  "additionalProperties": false
}
